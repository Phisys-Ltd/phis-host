#!/bin/sh
set -e

HOST_STATE_ROOT="/var/lib/phis/phis-host"
HOST_STAGE_DOC_ROOT="${HOST_STATE_ROOT}/stages"

ensure_dir() {
  install -d -m 0755 "$1"
}

apply_owner_if_present() {
  target="$1"

  if getent passwd phis >/dev/null 2>&1 && getent group phis >/dev/null 2>&1; then
    chown phis:phis "$target"
  fi
}

case "$1" in
  configure|abort-upgrade|abort-remove|abort-deconfigure)
    ensure_dir /var/lib/phis
    ensure_dir "${HOST_STATE_ROOT}"
    ensure_dir "${HOST_STAGE_DOC_ROOT}"

    apply_owner_if_present /var/lib/phis
    apply_owner_if_present "${HOST_STATE_ROOT}"
    apply_owner_if_present "${HOST_STAGE_DOC_ROOT}"
    ;;
esac

exit 0
